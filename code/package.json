{
  "name": "kai",
  "displayName": "Kai",
  "description": "Local agent that integrates with LM Studio local LLM API for chat and code tasks.",
  "version": "0.0.1",
  "publisher": "local-llm",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kai-agent-activitybar",
          "title": "Kai Agent",
          "icon": "media/svg/kai_icon.svg"
        }
      ]
    },
    "views": {
      "kai-agent-activitybar": [
        {
          "type": "webview",
          "id": "kai-chat-sidebar",
          "name": "Kai Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "kai.sendSelection",
        "title": "Kai: Send Code Selection to Chat"
      },
      {
        "command": "kai.focusChat",
        "title": "Kai: Focus Chat View"
      },
      {
        "command": "kai.inlineEdit",
        "title": "Kai: Inline Edit Selection"
      }
    ],
    "keybindings": [
      {
        "command": "kai.inlineEdit",
        "key": "ctrl+alt+k",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Kai Configuration",
      "properties": {
        "kai.serverUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "The base URL for your LM Studio local server API."
        },
        "kai.apiKey": {
          "type": "string",
          "default": "",
          "description": "The API key for Google Gemini models."
        },
        "kai.mistralApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Mistral AI free tier (console.mistral.ai)."
        },
        "kai.cohereApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Cohere free tier (dashboard.cohere.com)."
        },
        "kai.cerebrasApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Cerebras free tier (cloud.cerebras.ai)."
        },
        "kai.zhipuApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Zhipu AI (GLM) free tier (open.bigmodel.cn)."
        },
        "kai.omnirouteServerUrl": {
          "type": "string",
          "default": "http://localhost:8000/v1",
          "description": "Base URL for your OmniRoute AI gateway instance (run locally via npm: npx omniroute)."
        },
        "kai.omnirouteApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for OmniRoute AI gateway (if API key authentication is enabled)."
        },
        "kai.temperature": {
          "type": "number",
          "default": 0.7,
          "description": "Temperature parameter for chat completions (0.0 to 2.0)."
        },
        "kai.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "nl",
            "de",
            "fr",
            "es"
          ],
          "default": "auto",
          "description": "Language for Kai Agent UI and response messages."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  }
}

